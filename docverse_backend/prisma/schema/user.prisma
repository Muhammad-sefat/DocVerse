model User {
  id           String      @id @default(uuid())

  name         String
  email        String      @unique
  password     String

  role         UserRole    @default(USER)

  profileImage String?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // RELATIONS
  books         Book[]
  purchases     Purchase[]
  borrows       Borrow[]
  reviews       Review[]
  wishlists     Wishlist[]
  payments      Payment[]
}